---
import Dither from '../components/Dither';
import '../styles/global.css';
import {
  CircleCheck,
  Zap,
  Wind,
  Eye,
  ArrowBigDownDash,
  Stethoscope,
  LayoutGrid,
} from 'lucide-astro';
---

<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <link rel='icon' href='/favicon.ico' />
    <meta name='viewport' content='width=device-width' />
    <meta name='generator' content={Astro.generator} />
    <title>CV Mold Testing</title>
  </head>
  <body>
    <div
      id='green-overlay'
      class='w-full h-dvh fixed -z-40 pointer-events-none bg-[#31a948]'
      style='opacity: 0'
    >
    </div>
    <div class='w-full h-dvh fixed -z-50'>
      <Dither
        client:load
        waveColor={[0.5, 1, 0.45]}
        disableAnimation={false}
        enableMouseInteraction
        mouseRadius={0}
        colorNum={2}
        waveAmplitude={0.2}
        waveFrequency={3}
        waveSpeed={0.06}
      />
    </div>
    <div id='smooth-wrapper'>
      <div id='smooth-content'>
        <header class='bg-white rounded-lg mx-6 shadow mt-6'>
          <div
            class='max-w-500 mx-auto px-6 py-4 flex items-center justify-between'
          >
            <a href='#'><img src='/logo.svg' alt='CV Mold Testing' /></a>
            <nav class='flex items-center gap-x-8'>
              <a
                href='#steps'
                class='text-sm text-gray-600 hover:text-[#2C2F47] transition-colors'
                >How It Works</a
              >
              <a
                href='#plans'
                class='text-sm text-gray-600 hover:text-[#2C2F47] transition-colors'
                >Pricing</a
              >
              <a
                href='#contact'
                class='text-sm text-gray-600 hover:text-[#2C2F47] transition-colors'
                >Contact</a
              >
              <a
                href='#contact'
                class='rounded-lg bg-[#2C2F47] text-white text-sm py-2.5 px-5'
                >Schedule Your Test</a
              >
            </nav>
          </div>
        </header>
        <main class='mt-20 flex flex-col gap-y-40 px-6'>
          <section
            id='hero'
            class='w-full max-w-500 mx-auto grid grid-cols-12 gap-x-10'
          >
            <div
              class='flex flex-col gap-y-5 h-full justify-center items-start col-span-6'
            >
              <h1 class='text-7xl font-semibold text-pretty'>
                We detect and test mold in your home.
              </h1>
              <p class='text-pretty'>
                Professional mold inspection services for homeowners.
                Lab-certified testing, detailed reports, and expert guidance on
                next steps.
              </p>
              <button
                class='rounded-lg bg-[#2C2F47] inline-flex text-white py-3 px-6'
                >Schedule Your Test</button
              >
            </div>
            <div class='col-start-8 col-span-5'>
              <img
                class='rounded-lg'
                src='https://images.unsplash.com/photo-1570129477492-45c003edd2be?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D'
                alt=''
              />
            </div>
          </section>
          <section
            id='symptoms'
            class='w-full max-w-500 mx-auto grid grid-cols-12 gap-x-10 gap-y-10'
          >
            <h2 class='text-5xl font-semibold col-span-5 text-pretty self-end'>
              Mold: A Silent Enemy in Your Home
            </h2>
            <div class='col-span-6 col-start-7 self-end flex flex-col gap-y-4'>
              <p class='text-pretty'>
                Mold can grow anywhere there's moisture in your home without you
                even noticing. Behind walls, under carpets, in the bathroom or
                basement. As it grows, it releases spores that you and your
                family breathe every day.
              </p>
              <p class='text-pretty'>
                The problem? You can't always see it. And by the time you notice
                the signs, it may have already spread.
              </p>
            </div>
            <div class='col-span-12 flex gap-x-5'>
              <div
                class='bg-white p-6 flex flex-col justify-between rounded-lg flex-1 gap-y-16 shadow'
              >
                <Zap size='35' color='#2c2f47' />
                <p class='text-2xl text-pretty'>Frequent headache</p>
              </div>
              <div
                class='bg-white p-6 flex flex-col justify-between rounded-lg flex-1 gap-y-16 shadow'
              >
                <Wind size='35' color='#2c2f47' />
                <p class='text-2xl text-pretty'>
                  Nasal congestion and Sneezing
                </p>
              </div>
              <div
                class='bg-white p-6 flex flex-col justify-between rounded-lg flex-1 gap-y-16 shadow'
              >
                <Eye size='35' color='#2c2f47' />
                <p class='text-2xl text-pretty'>Eye and throat irritation</p>
              </div>
              <div
                class='bg-white p-6 flex flex-col justify-between rounded-lg flex-1 gap-y-16 shadow'
              >
                <ArrowBigDownDash size='35' color='#2c2f47' />
                <p class='text-2xl text-pretty'>Unexplained fatigue</p>
              </div>
              <div
                class='bg-white p-6 flex flex-col justify-between rounded-lg flex-1 gap-y-16 shadow'
              >
                <Stethoscope size='35' color='#2c2f47' />
                <p class='text-2xl text-pretty'>Respiratory issues</p>
              </div>
            </div>
          </section>
          <section
            id='why-test'
            class='h-[60dvh] max-w-500 mx-auto flex flex-col justify-center gap-y-10'
          >
            <p
              class='why-test-text text-center text-5xl font-semibold'
              style='color: transparent'
            >
              A professional mold test gives you the information you need to
              protect your home and your family.
            </p>
            <p
              class='why-test-text text-center text-5xl font-semibold'
              style='color: transparent'
            >
              Whether you're experiencing symptoms, dealing with moisture
              issues, or simply want peace of mind — testing is the first step.
            </p>
          </section>
          <section id='steps' class='w-full max-w-500 mx-auto'>
            <h2
              class='text-5xl font-semibold col-span-5 text-pretty self-end mb-10'
            >
              Professional Mold Testing in 4 Simple Steps
            </h2>
            <div class='grid grid-cols-12 gap-x-6 gap-y-6'>
              <div class='col-span-3 flex flex-col gap-y-4'>
                <img
                  class='w-full h-auto rounded-lg'
                  src='https://images.unsplash.com/photo-1583847268964-b28dc8f51f92'
                  alt='Book your test'
                />
                <span
                  class='text-sm font-semibold uppercase tracking-widest text-[#2C2F47]'
                  >Step 1</span
                >
                <h3 class='text-xl font-semibold'>Book Your Test</h3>
                <p class='text-sm text-pretty'>
                  Contact us to schedule a visit. We'll find a time that works
                  for you.
                </p>
              </div>
              <div class='col-span-3 flex flex-col gap-y-4'>
                <img
                  class='w-full h-auto rounded-lg'
                  src='https://images.unsplash.com/photo-1583847268964-b28dc8f51f92'
                  alt='Professional inspection'
                />
                <span
                  class='text-sm font-semibold uppercase tracking-widest text-[#2C2F47]'
                  >Step 2</span
                >
                <h3 class='text-xl font-semibold'>Professional Inspection</h3>
                <p class='text-sm text-pretty'>
                  Our certified team visits your home and collects air and
                  surface samples from the areas you select.
                </p>
              </div>
              <div class='col-span-3 flex flex-col gap-y-4'>
                <img
                  class='w-full h-auto rounded-lg'
                  src='https://images.unsplash.com/photo-1583847268964-b28dc8f51f92'
                  alt='Lab analysis'
                />
                <span
                  class='text-sm font-semibold uppercase tracking-widest text-[#2C2F47]'
                  >Step 3</span
                >
                <h3 class='text-xl font-semibold'>Lab Analysis</h3>
                <p class='text-sm text-pretty'>
                  Samples are sent to a certified laboratory for detailed
                  analysis. We identify the type of mold present and its
                  concentration levels.
                </p>
              </div>
              <div class='col-span-3 flex flex-col gap-y-4'>
                <img
                  class='w-full h-auto rounded-lg'
                  src='https://images.unsplash.com/photo-1583847268964-b28dc8f51f92'
                  alt='Detailed report'
                />
                <span
                  class='text-sm font-semibold uppercase tracking-widest text-[#2C2F47]'
                  >Step 4</span
                >
                <h3 class='text-xl font-semibold'>
                  Detailed Report & Next Steps
                </h3>
                <p class='text-sm text-pretty'>
                  You receive a complete report with the results. If mold is
                  found, we'll connect you with trusted professionals who can
                  help you solve the problem.
                </p>
              </div>
            </div>
          </section>
          <section id='test-description' class='w-full max-w-500 mx-auto'>
            <h2 class='w-full text-center text-5xl font-semibold mb-10'>
              What You Get With Every Test
            </h2>
            <ul
              class='grid grid-cols-12 col-start-2 col-span-10 gap-x-20 gap-y-3 text-2xl'
            >
              <li class='col-span-4 col-start-3 flex items-baseline gap-2'>
                <CircleCheck
                  size='24'
                  class='shrink-0 translate-y-1'
                />Professional on-site visit
              </li>
              <li class='col-span-4 flex items-baseline gap-2'>
                <CircleCheck size='24' class='shrink-0 translate-y-1' />Detailed
                report with mold types
              </li>
              <li class='col-span-4 col-start-3 flex items-baseline gap-2'>
                <CircleCheck
                  size='24'
                  class='shrink-0 translate-y-1'
                />Certified sample collection
              </li>
              <li class='col-span-4 flex items-baseline gap-2'>
                <CircleCheck size='24' class='shrink-0 translate-y-1' />Expert
                guidance on recommended next steps
              </li>
              <li class='col-span-4 col-start-3 flex items-baseline gap-2'>
                <CircleCheck
                  size='24'
                  class='shrink-0 translate-y-1'
                />Mandatory exterior test at no extra charge
              </li>
              <li class='col-span-4 flex items-baseline gap-2'>
                <CircleCheck
                  size='24'
                  class='shrink-0 translate-y-1'
                />Connection with trusted remediation professionals
              </li>
              <li class='col-span-4 col-start-3 flex items-baseline gap-2'>
                <CircleCheck size='24' class='shrink-0 translate-y-1' />Lab
                analysis by a certified laboratory
              </li>
            </ul>
          </section>
          <section
            id='plans'
            class='w-full max-w-500 mx-auto grid grid-cols-12 gap-x-10 gap-y-10'
          >
            <div class='col-span-4'>
              <h2 class='w-full text-5xl font-semibold mb-10 text-pretty'>
                Choose the Right Test for Your Home
              </h2>
              <p class='mb-4'>
                Each home is different. Select the package that fits your needs
                based on the number of areas you want to test.
              </p>
              <small
                >* Each area typically requires 2 test samples for accurate
                results. Not sure how many areas you need? Contact us and we'll
                help you decide</small
              >
            </div>
            <div class='col-span-6 col-start-7 flex flex-col gap-y-5'>
              <div
                class='card bg-white border p-8 flex justify-between gap-y-3 rounded-2xl border-[#E7E3E4]'
              >
                <div class='flex flex-col gap-y-4 w-2/3'>
                  <small class='uppercase tracking-[0.2rem]'>Basic</small>
                  <p class='text-balance text-gray-500 leading-5 text-lg'>
                    Perfect for smaller homes or specific concerns in a few
                    rooms.
                  </p>
                  <p class='flex items-center text-sm gap-x-1'>
                    <LayoutGrid size='14' /> 4 areas tested + free exterior test
                  </p>
                </div>
                <div class='flex flex-col justify-center items-center w-1/3'>
                  <span class='text-6xl font-bold'>$299</span>
                </div>
              </div>
              <div
                class='card bg-white border p-8 flex justify-between gap-y-3 rounded-2xl border-[#E7E3E4]'
              >
                <div class='flex flex-col gap-y-4 w-2/3'>
                  <small class='uppercase tracking-[0.2rem]'>Standard</small>
                  <p class='text-balance text-gray-500 leading-5 text-lg'>
                    Ideal for medium-sized homes or when you want broader
                    coverage.
                  </p>
                  <p class='flex items-center text-sm gap-x-1'>
                    <LayoutGrid size='14' /> 6 areas tested + free exterior test
                  </p>
                </div>
                <div class='flex flex-col justify-center items-center w-1/3'>
                  <span class='text-6xl font-bold'>$449</span>
                </div>
              </div>
              <div
                class='card bg-white border-2 p-8 flex justify-between gap-y-3 rounded-2xl border-[#2C2F47]'
              >
                <div class='flex flex-col gap-y-4 w-2/3'>
                  <div class='flex items-center gap-x-2'>
                    <small class='uppercase tracking-[0.2rem]'>Complete</small>
                    <span
                      class='text-xs font-semibold bg-[#2C2F47] rounded px-2 py-0.5'
                      style='color: #fff'>Best Value</span
                    >
                  </div>
                  <p class='text-balance text-gray-500 leading-5 text-lg'>
                    Comprehensive testing for larger homes or full peace of
                    mind.
                  </p>
                  <p class='flex items-center text-sm gap-x-1'>
                    <LayoutGrid size='14' /> 8 areas tested + free exterior test
                  </p>
                </div>
                <div class='flex flex-col justify-center items-center w-1/3'>
                  <span class='text-6xl font-bold'>$549</span>
                </div>
              </div>
              <div
                class='card bg-white border p-8 flex justify-between gap-y-3 rounded-2xl border-[#E7E3E4]'
              >
                <div class='flex flex-col gap-y-4 w-2/3'>
                  <small class='uppercase tracking-[0.2rem]'>Custom</small>
                  <p class='text-balance text-gray-500 leading-5 text-lg'>
                    More areas, a commercial space, or not sure where to start?
                    We'll put together a quote for you.
                  </p>
                  <p class='flex items-center text-sm gap-x-1'>
                    <LayoutGrid size='14' /> Tailored to your space
                  </p>
                </div>
                <div class='flex flex-col justify-center items-center w-1/3'>
                </div>
              </div>
            </div>
          </section>
          <section
            id='last-call'
            class='w-full max-w-400 mx-auto flex flex-col gap-y-10 items-center'
          >
            <p class='text-center text-5xl font-semibold text-black'>
              A professional mold test gives you the information you need to
              protect your home and your family.
            </p>
            <p class='text-center text-5xl font-semibold text-black'>
              Whether you're experiencing symptoms, dealing with moisture
              issues, or simply want peace of mind — testing is the first step.
            </p>
          </section>
          <section
            id='contact'
            class='w-full max-w-500 mx-auto grid grid-cols-12 gap-x-10 gap-y-10'
          >
            <div class='col-span-4'>
              <h2 class='w-full text-5xl font-semibold mb-10 text-pretty'>
                Schedule Your Mold Test
              </h2>
              <p class='text-balance mb-4'>
                Fill out the form and we'll get back to you within 24 hours to
                book your inspection or contact us:
              </p>
              <ul>
                <li>+1 305 397 4966</li>
                <li>+1 305 397 4966</li>
                <li>info@cvmoldtesting.com</li>
              </ul>
            </div>
            <div class='col-span-7 col-start-6 flex flex-col gap-y-5'>
              <form action='' class='grid grid-cols-6 gap-x-5'>
                <div class='col-span-3 flex flex-col mb-4'>
                  <label for='' class='mb-2 text-sm'>Name</label>
                  <input
                    type='text'
                    class='w-full bg-white rounded-lg border border-[#E7E3E4] p-3 outline-none focus:ring-2 focus:ring-[#2C2F47] transition-all duration-200'
                  />
                </div>
                <div class='col-span-3 flex flex-col mb-4'>
                  <label for='' class='mb-2 text-sm'>Email</label>
                  <input
                    type='email'
                    class='w-full bg-white rounded-lg border border-[#E7E3E4] p-3 outline-none focus:ring-2 focus:ring-[#2C2F47] transition-all duration-200'
                  />
                </div>
                <div class='col-span-3 flex flex-col mb-4'>
                  <label for='' class='mb-2 text-sm'>Phone</label>
                  <input
                    type='text'
                    class='w-full bg-white rounded-lg border border-[#E7E3E4] p-3 outline-none focus:ring-2 focus:ring-[#2C2F47] transition-all duration-200'
                  />
                </div>
                <div class='col-span-3 flex flex-col mb-4'>
                  <label for='' class='mb-2 text-sm'>Zip Code</label>
                  <input
                    type='email'
                    class='w-full bg-white rounded-lg border border-[#E7E3E4] p-3 outline-none focus:ring-2 focus:ring-[#2C2F47] transition-all duration-200'
                  />
                </div>
                <div class='col-span-6 flex flex-col mb-4'>
                  <label class='mb-2 text-sm'>Choose your plan</label>
                  <div class='grid grid-cols-4 gap-3'>
                    <label
                      class='relative block bg-white cursor-pointer rounded-lg border border-[#E7E3E4] p-4 leading-5 pb-6 transition-all duration-200 has-checked:border-[#2C2F47] has-checked:shadow-[0_0_0_2px_#2C2F47] text-3xl'
                      for='plan-basic'
                    >
                      <input
                        type='radio'
                        class='absolute top-4 right-4 h-4 w-4 accent-[#2C2F47]'
                        name='plan'
                        id='plan-basic'
                        value='basic'
                      />
                      <span class='uppercase text-sm block mb-4 tracking-widest'
                        >Basic</span
                      >
                      4 areas
                    </label>
                    <label
                      class='relative block bg-white cursor-pointer rounded-lg border border-[#E7E3E4] p-4 leading-5 pb-6 transition-all duration-200 has-checked:border-[#2C2F47] has-checked:shadow-[0_0_0_2px_#2C2F47] text-3xl'
                      for='plan-standard'
                    >
                      <input
                        type='radio'
                        class='absolute top-3 right-3 h-4 w-4 accent-[#2C2F47]'
                        name='plan'
                        id='plan-standard'
                        value='standard'
                      />
                      <span class='uppercase text-sm block mb-4 tracking-widest'
                        >Standard</span
                      >
                      6 areas
                    </label>
                    <label
                      class='relative block bg-white cursor-pointer rounded-lg border border-[#E7E3E4] p-4 leading-5 pb-6 transition-all duration-200 has-checked:border-[#2C2F47] has-checked:shadow-[0_0_0_2px_#2C2F47] text-3xl'
                      for='plan-complete'
                    >
                      <input
                        type='radio'
                        class='absolute top-3 right-3 h-4 w-4 accent-[#2C2F47]'
                        name='plan'
                        id='plan-complete'
                        value='complete'
                      />
                      <span class='uppercase text-sm block mb-4 tracking-widest'
                        >Complete</span
                      >
                      8 areas
                    </label>
                    <label
                      class='relative block bg-white cursor-pointer rounded-lg border border-[#E7E3E4] p-4 leading-5 pb-6 transition-all duration-200 has-checked:border-[#2C2F47] has-checked:shadow-[0_0_0_2px_#2C2F47] text-3xl'
                      for='plan-custom'
                    >
                      <input
                        type='radio'
                        class='absolute top-3 right-3 h-4 w-4 accent-[#2C2F47]'
                        name='plan'
                        id='plan-custom'
                        value='custom'
                      />
                      <span class='uppercase text-sm block mb-4 tracking-widest'
                        >Custom</span
                      >
                      X areas
                    </label>
                  </div>
                </div>
                <div class='col-span-6 flex flex-col mb-6'>
                  <label for='' class='mb-2 text-sm'>Additional comments</label>
                  <textarea
                    name=''
                    id=''
                    class='bg-white rounded-lg border border-[#E7E3E4] p-3 outline-none focus:ring-2 focus:ring-[#2C2F47] transition-all duration-200'
                  ></textarea>
                </div>
                <div class='col-span-6'>
                  <button
                    class='rounded-lg bg-[#2C2F47] inline-flex text-white py-3 px-6'
                    >Request My Test</button
                  >
                </div>
              </form>
            </div>
          </section>
        </main>
        <footer
          class='bg-white w-full mt-25 p-5 pb-11 border-t border-[#E7E3E4]'
        >
          <div
            class='max-w-500 mx-auto flex justify-between text-sm items-center'
          >
            <p>© 2026 CV Mold Testing LLC</p>
            <ul class='flex gap-x-4'>
              <li>Instagram</li>
              <li>Whatsapp</li>
            </ul>
            <ul class='flex gap-x-6'>
              <li><a href='#'>Privacy Policy</a></li>
              <li><a href='#'>Cookie Policy</a></li>
            </ul>
          </div>
        </footer>
      </div>
    </div>
    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import { ScrollSmoother } from 'gsap/ScrollSmoother';

      gsap.registerPlugin(ScrollTrigger, ScrollSmoother);

      ScrollSmoother.create({
        wrapper: '#smooth-wrapper',
        content: '#smooth-content',
        smooth: 1.5,
        effects: true,
      });

      window.addEventListener('load', () => {
        ScrollTrigger.refresh();
      });

      const texts = gsap.utils.toArray<HTMLElement>('.why-test-text');
      const greenOverlay = document.getElementById('green-overlay')!;
      const adjacentSections = ['#symptoms', '#steps'].map(
        (id) => document.querySelector(id)!,
      );

      gsap
        .timeline({
          scrollTrigger: {
            trigger: '#why-test',
            start: 'top 70%',
            end: 'bottom 30%',
            scrub: 0.8,
          },
        })
        .to(greenOverlay, { opacity: 1, duration: 0.4 }, 0)
        .to(adjacentSections, { opacity: 0, duration: 0.4 }, 0)
        .to(texts, { color: '#ffffff', duration: 0.4, stagger: 0.15 }, 0)
        .to(texts, { color: '#000000', duration: 0.4, stagger: 0.15 }, 0.6)
        .to(greenOverlay, { opacity: 0, duration: 0.4 }, 0.6)
        .to(adjacentSections, { opacity: 1, duration: 0.4 }, 0.6);
    </script>
  </body>
</html>
