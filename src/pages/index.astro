    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import { ScrollSmoother } from 'gsap/ScrollSmoother';

      gsap.registerPlugin(ScrollTrigger, ScrollSmoother);

      const smoother = ScrollSmoother.create({
        wrapper: '#smooth-wrapper',
        content: '#smooth-content',
        smooth: 1.5,
        effects: true,
      });

      window.addEventListener('load', () => {
        ScrollTrigger.refresh();
      });

      document.querySelectorAll('a[href^="#"]').forEach((link) => {
        link.addEventListener('click', (e) => {
          const href = link.getAttribute('href');
          if (!href || href === '#') return;
          const target = document.querySelector(href);
          if (!target) return;
          e.preventDefault();
          smoother.scrollTo(target, true, 'top 80px');
        });
      });

      const texts = gsap.utils.toArray<HTMLElement>('.why-test-text');
      const greenOverlay = document.getElementById('green-overlay')!;
      const adjacentSections = ['#symptoms', '#steps'].map(
        (id) => document.querySelector(id)!,
      );

      gsap
        .timeline({
          scrollTrigger: {
            trigger: '#why-test',
            start: 'top 70%',
            end: 'bottom 30%',
            scrub: 0.8,
          },
        })
        .to(greenOverlay, { opacity: 1, duration: 0.4 }, 0)
        .to(adjacentSections, { opacity: 0, duration: 0.4 }, 0)
        .to(texts, { color: '#ffffff', duration: 0.4, stagger: 0.15 }, 0)
        .to(texts, { color: '#2c2f47', duration: 0.4, stagger: 0.15 }, 0.6)
        .to(greenOverlay, { opacity: 0, duration: 0.4 }, 0.6)
        .to(adjacentSections, { opacity: 1, duration: 0.4 }, 0.6);
    </script>
