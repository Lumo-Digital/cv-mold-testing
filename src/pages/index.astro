---
import Dither from '../components/Dither';
import '../styles/global.css';
import {
  CircleCheck,
  Zap,
  Wind,
  Eye,
  ArrowBigDownDash,
  Stethoscope,
  LayoutGrid,
  Gift,
  Menu,
  X,
} from 'lucide-astro';
---

<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <link rel='icon' href='/favicon.ico' />
    <meta name='viewport' content='width=device-width' />
    <meta name='generator' content={Astro.generator} />
    <title>CV Mold Testing</title>
  </head>
  <body>
    <div
      id='green-overlay'
      class='w-full h-dvh fixed -z-40 pointer-events-none bg-[#31a948]'
      style='opacity: 0'
    >
    </div>
    <div class='w-full h-dvh fixed -z-50'>
      <Dither
        client:load
        waveColor={[0.5, 1, 0.45]}
        disableAnimation={false}
        enableMouseInteraction
        mouseRadius={0}
        colorNum={2}
        waveAmplitude={0.2}
        waveFrequency={3}
        waveSpeed={0.06}
      />
    </div>
    <div id='smooth-wrapper'>
      <div id='smooth-content'>
        <header class='bg-white rounded-lg mx-6 shadow mt-6 relative'>
          <div class='px-6 py-4 flex items-center justify-between'>
            <a href='#'><img src='/logo.svg' alt='CV Mold Testing' /></a>
            <nav class='max-[768px]:hidden flex items-center gap-x-8'>
              <a
                href='#steps'
                class='text-sm text-gray-600 hover:text-[#2C2F47] transition-colors'
                >How It Works</a
              >
              <a
                href='#plans'
                class='text-sm text-gray-600 hover:text-[#2C2F47] transition-colors'
                >Pricing</a
              >
              <a
                href='#contact'
                class='text-sm text-gray-600 hover:text-[#2C2F47] transition-colors'
                >Contact</a
              >
              <a
                href='#contact'
                class='rounded-lg bg-[#2C2F47] text-white text-sm py-2.5 px-5'
                >Schedule Your Test</a
              >
            </nav>
            <button
              id='hamburger'
              class='hidden max-[768px]:flex items-center justify-center p-2 rounded-lg hover:bg-gray-100 transition-colors'
              aria-label='Open menu'
            >
              <span id='icon-menu'><Menu size='22' color='#2C2F47' /></span>
              <span id='icon-close' class='hidden'
                ><X size='22' color='#2C2F47' /></span
              >
            </button>
          </div>
          <div
            id='mobile-menu'
            class='hidden flex-col absolute top-full left-0 right-0 bg-white rounded-b-lg shadow-lg px-6 py-5 gap-y-4 z-50'
          >
            <a
              href='#steps'
              class='text-sm text-gray-600 hover:text-[#2C2F47] transition-colors'
              >How It Works</a
            >
            <a
              href='#plans'
              class='text-sm text-gray-600 hover:text-[#2C2F47] transition-colors'
              >Pricing</a
            >
            <a
              href='#contact'
              class='text-sm text-gray-600 hover:text-[#2C2F47] transition-colors'
              >Contact</a
            >
            <a
              href='#contact'
              class='rounded-lg bg-[#2C2F47] text-white text-sm py-2.5 px-5 text-center'
              >Schedule Your Test</a
            >
          </div>
        </header>
        <script>
          const hamburger = document.getElementById('hamburger');
          const mobileMenu = document.getElementById('mobile-menu');
          const iconMenu = document.getElementById('icon-menu');
          const iconClose = document.getElementById('icon-close');

          hamburger?.addEventListener('click', () => {
            const isOpen = !mobileMenu?.classList.contains('hidden');
            mobileMenu?.classList.toggle('hidden', isOpen);
            mobileMenu?.classList.toggle('flex', !isOpen);
            iconMenu?.classList.toggle('hidden', !isOpen);
            iconClose?.classList.toggle('hidden', isOpen);
          });

          mobileMenu?.querySelectorAll('a').forEach((link) => {
            link.addEventListener('click', () => {
              mobileMenu.classList.add('hidden');
              mobileMenu.classList.remove('flex');
              iconMenu?.classList.remove('hidden');
              iconClose?.classList.add('hidden');
            });
          });
        </script>
        <main class='mt-20 max-[768px]:mt-10 flex flex-col gap-y-40 px-6'>
          <section
            id='hero'
            class='w-full max-w-400 mx-auto grid grid-cols-12 gap-x-10 max-[800px]:gap-x-0 gap-y-8'
          >
            <div
              class='col-start-8 col-span-5 h-full max-[800px]:col-start-1 max-[800px]:col-span-12 max-[800px]:row-start-1 max-[768px]:h-80'
            >
              <img
                class='rounded-lg w-full h-full object-cover'
                src='https://images.unsplash.com/photo-1570129477492-45c003edd2be?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D'
                alt=''
              />
            </div>
            <div
              class='flex flex-col gap-y-5 h-full justify-center items-start col-start-1 col-span-6 row-start-1 max-[800px]:col-span-12 max-[800px]:row-start-2'
            >
              <h1
                class='text-7xl max-[768px]:text-5xl font-semibold text-pretty'
              >
                We detect and test mold in your home.
              </h1>
              <p class='text-pretty text-xl leading-6'>
                Professional mold inspection services for homeowners.
                Lab-certified testing, detailed reports, and expert guidance on
                next steps.
              </p>
              <button
                class='rounded-lg bg-[#2C2F47] inline-flex text-white py-3 px-6'
                >Schedule Your Test</button
              >
            </div>
          </section>
          <section
            id='symptoms'
            class='w-full max-w-400 mx-auto grid grid-cols-12 gap-x-10 max-sm:gap-x-0 gap-y-10'
          >
            <h2
              class='text-5xl max-lg:text-4xl font-semibold col-span-6 max-md:col-span-12 text-pretty self-end'
            >
              Mold: A Silent Enemy in Your Home
            </h2>
            <div
              class='col-span-12 grid grid-cols-5 max-lg:grid-cols-2 max-sm:grid-cols-1 gap-5'
            >
              <div
                class='bg-white p-6 flex flex-col justify-between rounded-lg gap-y-16 shadow'
              >
                <Zap size='35' color='#2c2f47' />
                <p class='text-xl text-pretty'>Frequent headache</p>
              </div>
              <div
                class='bg-white p-6 flex flex-col justify-between rounded-lg gap-y-16 shadow'
              >
                <Wind size='35' color='#2c2f47' />
                <p class='text-xl text-pretty'>Nasal congestion and Sneezing</p>
              </div>
              <div
                class='bg-white p-6 flex flex-col justify-between rounded-lg gap-y-16 shadow'
              >
                <Eye size='35' color='#2c2f47' />
                <p class='text-xl text-pretty'>Eye and throat irritation</p>
              </div>
              <div
                class='bg-white p-6 flex flex-col justify-between rounded-lg gap-y-16 shadow'
              >
                <ArrowBigDownDash size='35' color='#2c2f47' />
                <p class='text-xl text-pretty'>Unexplained fatigue</p>
              </div>
              <div
                class='bg-white p-6 flex flex-col justify-between rounded-lg gap-y-16 shadow'
              >
                <Stethoscope size='35' color='#2c2f47' />
                <p class='text-xl text-pretty'>Respiratory issues</p>
              </div>
            </div>
            <p
              class='col-span-12 max-sm:col-span-12 text-pretty text-xl leading-6'
            >
              Mold can grow anywhere there's moisture in your home without you
              even noticing. Behind walls, under carpets, in the bathroom or
              basement. As it grows, it releases spores that you and your family
              breathe every day.
            </p>
          </section>
          <section
            id='why-test'
            class='h-[30dvh] max-w-400 mx-auto flex flex-col justify-center gap-y-10'
          >
            <p
              class='why-test-text text-center text-5xl max-lg:text-4xl font-semibold'
              style='color: transparent'
            >
              A professional mold test gives you the information you need to
              protect your home and your family.
            </p>
            <p
              class='why-test-text text-center text-5xl max-lg:text-4xl font-semibold'
              style='color: transparent'
            >
              Whether you're experiencing symptoms, dealing with moisture
              issues, or simply want peace of mind — testing is the first step.
            </p>
          </section>
          <section id='steps' class='w-full max-w-400 mx-auto'>
            <h2
              class='text-5xl max-lg:text-4xl font-semibold col-span-5 text-pretty self-end mb-10'
            >
              Professional Mold Testing in 4 Simple Steps
            </h2>
            <div class='grid grid-cols-12 gap-x-6 gap-y-6'>
              <div
                class='col-span-3 max-xl:col-span-6 max-md:col-span-12 relative rounded-lg overflow-hidden h-96 max-md:h-64'
              >
                <img
                  class='absolute inset-0 w-full h-full object-cover'
                  src='https://images.unsplash.com/photo-1583847268964-b28dc8f51f92'
                  alt='Book your test'
                />
                <div
                  class='absolute inset-0 bg-linear-to-t from-[#2C2F47] via-[#2C2F47]/60 to-transparent'
                >
                </div>
                <div class='absolute inset-0 p-6 flex flex-col justify-end'>
                  <span
                    class='text-white text-xs font-semibold uppercase tracking-widest mb-3 opacity-70'
                    >Step 1</span
                  >
                  <h3 class='text-white text-2xl font-semibold mb-2'>
                    Book Your Test
                  </h3>
                  <p class='text-white text-sm leading-5 opacity-80'>
                    Contact us to schedule a visit. We'll coordinate a time that
                    fits your schedule — weekdays or weekends. Our team is
                    flexible and will guide you through every detail before the
                    appointment so you know exactly what to expect on inspection
                    day.
                  </p>
                </div>
              </div>
              <div
                class='col-span-3 max-xl:col-span-6 max-md:col-span-12 relative rounded-lg overflow-hidden h-96 max-md:h-64'
              >
                <img
                  class='absolute inset-0 w-full h-full object-cover'
                  src='https://images.unsplash.com/photo-1583847268964-b28dc8f51f92'
                  alt='Professional inspection'
                />
                <div
                  class='absolute inset-0 bg-linear-to-t from-[#2C2F47] via-[#2C2F47]/60 to-transparent'
                >
                </div>
                <div class='absolute inset-0 p-6 flex flex-col justify-end'>
                  <span
                    class='text-white text-xs font-semibold uppercase tracking-widest mb-3 opacity-70'
                    >Step 2</span
                  >
                  <h3 class='text-white text-2xl font-semibold mb-2'>
                    Professional Inspection
                  </h3>
                  <p class='text-white text-sm leading-5 opacity-80'>
                    Our certified team visits your home and collects air and
                    surface samples from the areas you select. We also perform a
                    comprehensive moisture mapping to identify hidden sources of
                    moisture that could contribute to mold growth.
                  </p>
                </div>
              </div>
              <div
                class='col-span-3 max-xl:col-span-6 max-md:col-span-12 relative rounded-lg overflow-hidden h-96 max-md:h-64'
              >
                <img
                  class='absolute inset-0 w-full h-full object-cover'
                  src='https://images.unsplash.com/photo-1583847268964-b28dc8f51f92'
                  alt='Lab analysis'
                />
                <div
                  class='absolute inset-0 bg-linear-to-t from-[#2C2F47] via-[#2C2F47]/60 to-transparent'
                >
                </div>
                <div class='absolute inset-0 p-6 flex flex-col justify-end'>
                  <span
                    class='text-white text-xs font-semibold uppercase tracking-widest mb-3 opacity-70'
                    >Step 3</span
                  >
                  <h3 class='text-white text-2xl font-semibold mb-2'>
                    Lab Analysis
                  </h3>
                  <p class='text-white text-sm leading-5 opacity-80'>
                    Samples are sent to a certified laboratory for detailed
                    analysis. We identify the type of mold present and its
                    concentration levels. Results are typically available within
                    3 to 5 business days, giving you accurate data to make
                    informed decisions about your home.
                  </p>
                </div>
              </div>
              <div
                class='col-span-3 max-xl:col-span-6 max-md:col-span-12 relative rounded-lg overflow-hidden h-96 max-md:h-64'
              >
                <img
                  class='absolute inset-0 w-full h-full object-cover'
                  src='https://images.unsplash.com/photo-1583847268964-b28dc8f51f92'
                  alt='Detailed report'
                />
                <div
                  class='absolute inset-0 bg-linear-to-t from-[#2C2F47] via-[#2C2F47]/60 to-transparent'
                >
                </div>
                <div class='absolute inset-0 p-6 flex flex-col justify-end'>
                  <span
                    class='text-white text-xs font-semibold uppercase tracking-widest mb-3 opacity-70'
                    >Step 4</span
                  >
                  <h3 class='text-white text-2xl font-semibold mb-2'>
                    Detailed Report & Next Steps
                  </h3>
                  <p class='text-white text-sm leading-5 opacity-80'>
                    You receive a complete report with findings for each area
                    tested, including mold type and concentration levels. If
                    mold is found, we'll connect you with trusted remediation
                    professionals who can help you solve the problem safely and
                    effectively.
                  </p>
                </div>
              </div>
            </div>
          </section>
          <section
            id='test-description'
            class='w-full max-w-400 mx-auto grid grid-cols-12 gap-x-10 max-sm:gap-x-0 gap-y-10'
          >
            <div class='col-span-4 max-lg:col-span-6 max-md:col-span-12'>
              <h2
                class='w-full text-5xl max-lg:text-4xl font-semibold mb-4 text-pretty'
              >
                What You Get With Every Test
              </h2>
              <p class='text-xl leading-6'>
                All the tests we perform includes the same comprehensive service
                — no hidden fees, no surprise add-ons.
              </p>
            </div>
            <ul
              class='col-span-6 col-start-7 max-md:col-span-12 max-md:col-start-1 flex flex-col gap-y-4 text-xl'
            >
              <li class='flex items-baseline gap-3'>
                <CircleCheck
                  size='22'
                  class='shrink-0 translate-y-0.5'
                />Professional on-site visit
              </li>
              <li class='flex items-baseline gap-3'>
                <CircleCheck
                  size='22'
                  class='shrink-0 translate-y-0.5'
                />Certified sample collection
              </li>
              <li class='flex items-baseline gap-3'>
                <CircleCheck size='22' class='shrink-0 translate-y-0.5' />Lab
                analysis by a certified laboratory
              </li>
              <li class='flex items-baseline gap-3'>
                <CircleCheck
                  size='22'
                  class='shrink-0 translate-y-0.5'
                />Detailed report with mold types
              </li>
              <li class='flex items-baseline gap-3'>
                <CircleCheck size='22' class='shrink-0 translate-y-0.5' />Expert
                guidance on recommended next steps
              </li>
              <li class='flex items-baseline gap-3'>
                <CircleCheck
                  size='22'
                  class='shrink-0 translate-y-0.5'
                />Mandatory exterior test at no extra charge
              </li>
              <li class='flex items-baseline gap-3'>
                <CircleCheck
                  size='22'
                  class='shrink-0 translate-y-0.5'
                />Connection with trusted remediation professionals
              </li>
            </ul>
          </section>
          <section
            id='plans'
            class='w-full max-w-400 mx-auto grid grid-cols-12 gap-x-10 gap-y-10 max-md:gap-x-0'
          >
            <div class='col-span-4 max-lg:col-span-6 max-md:col-span-12'>
              <h2
                class='w-full text-5xl max-lg:text-4xl font-semibold mb-4 text-pretty'
              >
                Choose the Right Test for Your Home
              </h2>
              <p class='mb-4 text-xl leading-6'>
                Every home is different. Select the package that fits your needs
                based on the number of areas you want to test.
              </p>
              <p class='text-sm leading-5'>
                Each area typically requires 2 test samples for accurate
                results. Not sure how many areas you need? Contact us and we'll
                help you decide
              </p>
            </div>
            <div
              class='col-span-6 col-start-7 max-md:col-span-12 max-md:col-start-1 flex flex-col gap-y-5'
            >
              <div
                class='card bg-white border p-8 grid grid-cols-[2fr_1fr] max-lg:grid-cols-1 gap-x-8 gap-y-4 rounded-2xl border-[#E7E3E4]'
              >
                <small class='uppercase tracking-[0.2rem]'>Basic</small>
                <div
                  class='row-span-3 max-lg:row-span-1 flex justify-center items-center max-lg:justify-start'
                >
                  <span class='text-6xl max-lg:text-5xl font-bold'>$299</span>
                </div>
                <p class='text-balance text-gray-500 leading-6 text-xl'>
                  Perfect for smaller homes or specific concerns in a few rooms.
                </p>
                <div class='flex flex-col text-sm gap-y-1'>
                  <p class='flex items-center gap-x-1'>
                    <LayoutGrid size='14' class='shrink-0' />3 areas tested
                  </p>
                  <p class='flex items-center gap-x-1'>
                    <Gift size='14' class='shrink-0' />Free exterior test
                  </p>
                </div>
              </div>
              <div
                class='card bg-white border p-8 grid grid-cols-[2fr_1fr] max-lg:grid-cols-1 gap-x-8 gap-y-4 rounded-2xl border-[#E7E3E4]'
              >
                <small class='uppercase tracking-[0.2rem]'>Standard</small>
                <div
                  class='row-span-3 max-lg:row-span-1 flex justify-center items-center max-lg:justify-start'
                >
                  <span class='text-6xl max-lg:text-5xl font-bold'>$449</span>
                </div>
                <p class='text-balance text-gray-500 leading-6 text-xl'>
                  Ideal for medium-sized homes or when you want broader
                  coverage.
                </p>
                <div class='flex flex-col text-sm gap-y-1'>
                  <p class='flex items-center gap-x-1'>
                    <LayoutGrid size='14' class='shrink-0' />6 areas tested
                  </p>
                  <p class='flex items-center gap-x-1'>
                    <Gift size='14' class='shrink-0' />Free exterior test
                  </p>
                </div>
              </div>
              <div
                class='card bg-white border-2 p-8 grid grid-cols-[2fr_1fr] max-lg:grid-cols-1 gap-x-8 gap-y-4 rounded-2xl border-[#2C2F47]'
              >
                <div class='flex items-center gap-x-2'>
                  <small class='uppercase tracking-[0.2rem]'>Complete</small>
                  <span
                    class='text-xs font-semibold bg-[#2C2F47] rounded px-2 py-0.5'
                    style='color: #fff'>Best Value</span
                  >
                </div>
                <div
                  class='row-span-3 max-lg:row-span-1 flex justify-center items-center max-lg:justify-start'
                >
                  <span class='text-6xl max-lg:text-5xl font-bold'>$549</span>
                </div>
                <p class='text-balance text-gray-500 leading-6 text-xl'>
                  Comprehensive testing for larger homes or full peace of mind.
                </p>
                <div class='flex flex-col text-sm gap-y-1'>
                  <p class='flex items-center gap-x-1'>
                    <LayoutGrid size='14' class='shrink-0' />8 areas tested
                  </p>
                  <p class='flex items-center gap-x-1'>
                    <Gift size='14' class='shrink-0' />Free exterior test
                  </p>
                </div>
              </div>
              <div
                class='card bg-white border p-8 grid grid-cols-[2fr_1fr] max-lg:grid-cols-1 gap-x-8 gap-y-4 rounded-2xl border-[#E7E3E4]'
              >
                <small class='uppercase tracking-[0.2rem]'>Custom</small>
                <div class='row-span-3 max-lg:row-span-1'></div>
                <p class='text-balance text-gray-500 leading-6 text-xl'>
                  More areas, a commercial space, or not sure where to start?
                  We'll put together a quote for you.
                </p>
                <p class='flex items-center text-sm gap-x-1'>
                  <LayoutGrid size='14' /> Tailored to your space
                </p>
              </div>
            </div>
          </section>
          <section
            id='last-call'
            class='w-full max-w-400 mx-auto flex flex-col gap-y-10 items-center'
          >
            <p class='text-center text-5xl max-lg:text-4xl font-semibold'>
              A professional mold test gives you the information you need to
              protect your home and your family.
            </p>
            <p class='text-center text-5xl max-lg:text-4xl font-semibold'>
              Whether you're experiencing symptoms, dealing with moisture
              issues, or simply want peace of mind — testing is the first step.
            </p>
          </section>
          <section
            id='contact'
            class='w-full max-w-400 mx-auto grid grid-cols-12 gap-x-10 max-[720px]:gap-x-0 gap-y-10'
          >
            <div class='col-span-4 max-lg:col-span-12'>
              <h2
                class='w-full text-5xl max-lg:text-4xl font-semibold mb-10 text-pretty'
              >
                Schedule Your Mold Test
              </h2>
              <p class='text-balance mb-4'>
                Fill out the form and we'll get back to you within 24 hours to
                book your inspection or contact us:
              </p>
              <ul>
                <li>+1 305 397 4966</li>
                <li>+1 305 397 4966</li>
                <li>info@cvmoldtesting.com</li>
              </ul>
            </div>
            <div
              class='col-span-7 col-start-6 max-lg:col-span-12 max-lg:col-start-1 flex flex-col gap-y-5'
            >
              <form action='' class='grid grid-cols-6 gap-x-5'>
                <div
                  class='col-span-6 min-[720px]:col-span-3 flex flex-col mb-4'
                >
                  <label for='' class='mb-2 text-sm'>Name</label>
                  <input
                    type='text'
                    class='w-full bg-white rounded-lg border border-[#E7E3E4] p-3 outline-none focus:ring-2 focus:ring-[#2C2F47] transition-all duration-200'
                  />
                </div>
                <div
                  class='col-span-6 min-[720px]:col-span-3 flex flex-col mb-4'
                >
                  <label for='' class='mb-2 text-sm'>Email</label>
                  <input
                    type='email'
                    class='w-full bg-white rounded-lg border border-[#E7E3E4] p-3 outline-none focus:ring-2 focus:ring-[#2C2F47] transition-all duration-200'
                  />
                </div>
                <div
                  class='col-span-6 min-[720px]:col-span-3 flex flex-col mb-4'
                >
                  <label for='' class='mb-2 text-sm'>Phone</label>
                  <input
                    type='text'
                    class='w-full bg-white rounded-lg border border-[#E7E3E4] p-3 outline-none focus:ring-2 focus:ring-[#2C2F47] transition-all duration-200'
                  />
                </div>
                <div
                  class='col-span-6 min-[720px]:col-span-3 flex flex-col mb-4'
                >
                  <label for='' class='mb-2 text-sm'>Zip Code</label>
                  <input
                    type='email'
                    class='w-full bg-white rounded-lg border border-[#E7E3E4] p-3 outline-none focus:ring-2 focus:ring-[#2C2F47] transition-all duration-200'
                  />
                </div>
                <div class='col-span-6 flex flex-col mb-4'>
                  <label class='mb-2 text-sm'>Choose your plan</label>
                  <div
                    class='grid grid-cols-1 min-[720px]:grid-cols-4 lg:grid-cols-2 min-[1440px]:grid-cols-4 gap-3'
                  >
                    <label
                      class='relative block bg-white cursor-pointer rounded-lg border border-[#E7E3E4] p-4 leading-5 transition-all duration-200 has-checked:border-[#2C2F47] has-checked:shadow-[0_0_0_2px_#2C2F47] text-xl lg:text-lg min-[1440px]:text-xl'
                      for='plan-basic'
                    >
                      <input
                        type='radio'
